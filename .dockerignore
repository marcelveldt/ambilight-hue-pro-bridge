# Keep build context small and — crucially — keep secrets out of the image. data/ holds the
# real bridge credentials (config.yaml) and the TLS keypair; it must never be baked in.
data/
*.log

.git/
.github/
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
*.egg-info/
build/
dist/

# Not needed at runtime (the package only ships ambilight_hue_bridge/*).
tests/
docs/
scripts/

.DS_Store
